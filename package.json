    "devDependencies": {
        "@types/diff-match-patch": "^1.0.32",
        "@types/node": "^16.11.6",
        "@typescript-eslint/eslint-plugin": "5.29.0",
        "@typescript-eslint/parser": "5.29.0",
        "builtin-modules": "3.3.0",
        "esbuild": "0.17.3",
        "obsidian": "latest",
        "tslib": "2.4.0",
        "typescript": "4.7.4"
    },
    "dependencies": {
        "@types/diff": "^7.0.2",
        "diff": "^8.0.3",
        "diff-match-patch": "^1.0.5",
        "marked": "^4.0.12",
        "turndown": "^7.1.1"

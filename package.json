{
  "name": "confluence-import",
  "version": "1.0.16",
  "description": "Import Confluence pages as local notes (one-way pull) with a read-only diff preview before anything is written.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "jest",
    "test:memory": "node scripts/test-memory.mjs",
    "package": "node scripts/package-release.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "sbom": "node scripts/generate-sbom.mjs",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian-plugin",
    "confluence",
    "markdown",
    "knowledge-management",
    "one-way-import",
    "diff-preview",
    "atlassian",
    "documentation",
    "import",
    "notes"
  ],
  "author": "hikosalaidarkcommit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hikosalaidarkcommit/confluence-import.git"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^16.11.6",
    "@typescript-eslint/eslint-plugin": "5.29.0",
    "@typescript-eslint/parser": "5.29.0",
    "esbuild": "0.28.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.4.1",
    "obsidian": "^1.13.1",
    "ts-jest": "^29.4.6",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  },
  "dependencies": {
    "@types/diff": "^7.0.2",
    "diff": "^8.0.3",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "homepage": "https://github.com/hikosalaidarkcommit/confluence-import"
}
